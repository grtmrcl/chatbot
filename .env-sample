# Discord Bot Token
# Discord Developer Portal → Bot → Token
token=YOUR_DISCORD_TOKEN

# Discord チャンネル設定
# JSON形式: {"チャンネルID": {"response_type": "default"}}
# チャンネルIDは https://discord.com/channels/XXX/YYY の YYY 部分
# 複数チャンネル例: {"111111111111111111": {"response_type": "default"}, "222222222222222222": {"response_type": "default"}}
DISCORD_SERVERS={"123456789012345678": {"response_type": "default", , "event_remind_label": ["ak", "ef"], "opebirth_label": ["ak", "ef"]}}

# Brave Search API
# https://api-dashboard.search.brave.com/ でAPIキーを取得
BRAVE_SEARCH_API_KEY=YOUR_BRAVE_SEARCH_API_KEY

# OpenAI API
# https://platform.openai.com/api-keys でAPIキーを取得
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google Cloud プロジェクト設定
# gcloud auth application-default set-quota-project でも設定可
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_QUOTA_PROJECT=your-project-id

# sss / ss-omikuji コマンド: スプレッドシート検索・おみくじ
# JSON形式: {"識別子": {"id": "SpreadsheetID", "sheet": "シート名"}}
# sheet を省略すると1枚目のシートを使用
# 認証は Application Default Credentials (ADC) を使用
SSS_SPREADSHEETS={"label1": {"id": "SpreadsheetID1", "sheet": "シート名"}}

# event-register / event-remind コマンド: イベント管理
# JSON形式: {"識別子": {"id": "SpreadsheetID", "sheet": "シート名"}}
EVENTS_SPREADSHEETS={"label1": {"id": "SpreadsheetID1", "sheet": "シート名"}}

# オペレーター一覧ツール (tool/operators.py)
# JSON形式: {"id": "SpreadsheetID", "sheet": "シート名"}
# sheet を省略すると1枚目のシートを使用。IDのみの文字列も可
AK_OPERATORS_SPREADSHEET={"id": "SpreadsheetID", "sheet": "シート名"}
EF_OPERATORS_SPREADSHEET={"id": "SpreadsheetID", "sheet": "シート名"}