# Discord Bot Token
# Discord Developer Portal → Bot → Token
token=YOUR_DISCORD_TOKEN

# Discord チャンネル設定
# JSON形式: {"チャンネルID": {"response_type": "default"}}
# チャンネルIDは https://discord.com/channels/XXX/YYY の YYY 部分
# 複数チャンネル例: {"111111111111111111": {"response_type": "default"}, "222222222222222222": {"response_type": "default"}}
DISCORD_SERVERS={"123456789012345678": {"response_type": "default"}}

# Google Custom Search API
# https://console.cloud.google.com/ でAPIキーを取得
# https://programmablesearchengine.google.com/ で検索エンジンIDを取得
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID

# OpenAI API
# https://platform.openai.com/api-keys でAPIキーを取得
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
